# HTML — revalidate each request (more specific rules below override)
/*
  Cache-Control: public, max-age=0, must-revalidate

# Fingerprinted build assets — immutable for 1 year
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static images in public/assets and root
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/*.woff
  Cache-Control: public, max-age=31536000, immutable
